# Минимум: один из ключей для выбранного провайдера
OPENAI_API_KEY=sk-your-openai-or-proxy-key

# Опционально (ProxyAPI / совместимые прокси)
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
DEFAULT_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4o-mini
REQUEST_TIMEOUT=30
LOG_LEVEL=INFO

# Claude (если используете Anthropic-ветку)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.proxyapi.ru/anthropic
CLAUDE_MODEL=claude-3-7-sonnet-20250219
CLAUDE_MAX_TOKENS=4096
REASONING_EFFORT=medium
