# ============================================================
# Portfolio root .gitignore
# Keeps the repository light — venvs, node_modules, secrets,
# build outputs and IDE droppings stay out of git.
# ============================================================

# --- Python ---
**/.venv/
**/venv/
_pip_check_venv/
_tai_venv/
**/env/
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
*.py[cod]
*.egg-info/
.coverage
htmlcov/

# --- Node.js / Next.js ---
**/node_modules/
**/.next/
**/dist/
**/build/
*.tsbuildinfo

# --- Environment & secrets ---
**/.env
**/.env.local
**/.env.*.local
**/google_token.json
**/yandex_token.json
**/.sync_state/
**/credentials.json
**/service-account*.json

# --- Logs, caches, local DBs ---
*.log
*.sqlite3
*.sqlite3-*
**/logs/
.cache/

# --- IDE / editors ---
.vscode/
.idea/
*.swp
*.swo

# --- Служебное автора (Cursor planning workspace) ---
.cursor/

# --- OS droppings ---
.DS_Store
Thumbs.db
desktop.ini

# --- Local-only assets (optional sandbox) ---
ASSETS/local/

# --- GitHub: hard limit 100 MB per file (push rejected) ---
# Видео/огромные дампы хранить локально или в LFS, не в обычном git.
**/*.mp4
**/tg_catalog*.db

# --- Pruned archive (kept locally, excluded from repo) ---
# Учебные обрывки и дубли, удалённые из 99-archive в Этапе 7.
# Папки физически остаются на диске у автора, но в репозиторий не возвращаются.
99-archive/api-testing-bot/
99-archive/auto-deploy-lesson/
99-archive/db-lessons/
99-archive/docker-lessons/
99-archive/langchain-lesson-1/
99-archive/langchain-lesson-2/
99-archive/llm-lessons/
99-archive/local-ai-agent/
99-archive/loki-grafana-stack/
99-archive/postgres-lessons/
99-archive/python-modules-lessons/
99-archive/python-oop-practice/
99-archive/recipe-search-bot/
99-archive/sql-lessons/
99-archive/sqlite-lesson/
