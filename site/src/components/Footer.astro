---
import { TELEGRAM, REPO_ROOT, REPO_TREE } from '../data/links';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <div>
      <strong class="footer-brand">Виталий Калугин</strong>
      <p class="footer-tagline muted">Данные, автоматизация, ИИ-продукты и веб-MVP — от идеи до продакшена.</p>
    </div>
    <div>
      <span class="footer-heading">Навигация</span>
      <ul class="footer-links">
        <li><a href={`${base}services/`}>Услуги</a></li>
        <li><a href={`${base}cases/`}>Кейсы</a></li>
        <li><a href={`${base}process/`}>Этапы</a></li>
        <li><a href={`${base}faq/`}>FAQ</a></li>
      </ul>
    </div>
    <div>
      <span class="footer-heading">Связь</span>
      <ul class="footer-links">
        <li>
          <a href={TELEGRAM} target="_blank" rel="noopener noreferrer" data-ym-goal="telegram_footer">Telegram @kaluginvit</a>
        </li>
        <li>
          <a href={REPO_ROOT} target="_blank" rel="noopener noreferrer" data-ym-goal="github_footer">Репозиторий Portfolio</a>
        </li>
        <li>
          <a href={REPO_TREE} target="_blank" rel="noopener noreferrer">Исходники кейсов</a>
        </li>
      </ul>
    </div>
  </div>
  <div class="wrap footer-bottom muted">
    © {year} · Сайт-визитка в репозитории Portfolio · Email для деловых запросов — по согласованию в Telegram.
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding: 3rem 0 1.5rem;
    border-top: 1px solid var(--border);
    background: var(--bg-subtle);
  }

  .footer-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
    padding-bottom: 2rem;
  }

  @media (min-width: 720px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }

  .footer-brand {
    display: block;
    color: var(--heading);
    margin-bottom: 0.35rem;
  }

  .footer-tagline {
    margin: 0;
    max-width: 36ch;
  }

  .footer-heading {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.65rem;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links li + li {
    margin-top: 0.35rem;
  }

  .footer-links a {
    font-weight: 500;
    text-decoration: none;
  }

  .footer-bottom {
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
  }
</style>
