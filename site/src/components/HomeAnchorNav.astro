---
/** Якорная навигация по главной (воронка как в референсе AmalSite). */
const links = [
  { href: '#audience', label: 'Для кого' },
  { href: '#includes', label: 'Что входит' },
  { href: '#portfolio', label: 'Кейсы' },
  { href: '#compare', label: 'Подход' },
  { href: '#process', label: 'Этапы' },
  { href: '#formats', label: 'Услуги' },
  { href: '#budget', label: 'Оценка' },
  { href: '#brief', label: 'Бриф' },
  { href: '#faq', label: 'FAQ' },
];
---

<nav class="anchor-nav" aria-label="Разделы страницы">
  {
    links.map((l) => (
      <a href={l.href} class="anchor-nav__link" data-ym-goal={`anchor_${l.href.slice(1)}`}>
        {l.label}
      </a>
    ))
  }
</nav>

<style>
  .anchor-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.55rem;
    justify-content: center;
    padding: 1.1rem 0 0;
    margin: 0.35rem 0 0;
    width: 100%;
    border-top: 1px solid var(--border);
  }

  .anchor-nav__link {
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 700;
    color: #4b5565;
    text-decoration: none;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.65);
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .anchor-nav__link:hover {
    color: var(--heading);
    background: #fff;
    border-color: rgba(199, 154, 82, 0.45);
  }
</style>
