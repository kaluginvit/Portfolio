---
import { TELEGRAM, REPO_ROOT } from '../data/links';

interface Props {
  current?: string;
}

const { current = '' } = Astro.props;
const base = import.meta.env.BASE_URL;

const nav = [
  { href: `${base}`, label: 'Главная', id: 'home' },
  { href: `${base}services/`, label: 'Услуги', id: 'services' },
  { href: `${base}cases/`, label: 'Кейсы', id: 'cases' },
  { href: `${base}process/`, label: 'Этапы', id: 'process' },
  { href: `${base}about/`, label: 'Доказательства', id: 'about' },
  { href: `${base}faq/`, label: 'FAQ', id: 'faq' },
  { href: `${base}contact/`, label: 'Контакты', id: 'contact' },
];
---

<header class="site-header">
  <div class="wrap header-inner">
    <a class="logo" href={base} data-ym-goal="logo_home">Виталий <span>Калугин</span></a>

    <nav class="nav-desktop" aria-label="Основное">
      {
        nav.map((item) => (
          <a href={item.href} class:list={['nav-link', { active: current === item.id }]} data-ym-goal={`nav_${item.id}`}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <a class="btn btn-primary btn-sm" href={TELEGRAM} target="_blank" rel="noopener noreferrer" data-ym-goal="telegram_header">
        Telegram
      </a>
      <a class="btn btn-ghost btn-sm gh" href={REPO_ROOT} target="_blank" rel="noopener noreferrer" data-ym-goal="github_header">
        GitHub
      </a>
    </div>

    <details class="nav-mobile">
      <summary class="nav-burger" aria-label="Меню">
        <span></span><span></span><span></span>
      </summary>
      <div class="nav-mobile-panel">
        {
          nav.map((item) => (
            <a href={item.href} class:list={['nav-mobile-link', { active: current === item.id }]}>
              {item.label}
            </a>
          ))
        }
        <a class="btn btn-primary" href={TELEGRAM} target="_blank" rel="noopener noreferrer" data-ym-goal="telegram_menu">
          Написать в Telegram
        </a>
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    box-shadow: none;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: var(--header-h);
  }

  .logo {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(26px, 3vw, 34px);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--heading);
    text-decoration: none;
    margin-right: auto;
  }

  .logo span {
    color: var(--teal);
  }

  .logo:hover {
    opacity: 0.92;
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 1.75rem;
  }

  @media (min-width: 960px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    padding: 0.35rem 0;
    font-size: 15px;
    font-weight: 700;
    color: #4b5565;
    text-decoration: none;
    border-radius: 0;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
    background: transparent;
    border-bottom-color: var(--gold);
  }

  .header-actions {
    display: none;
    align-items: center;
    gap: 0.5rem;
  }

  @media (min-width: 960px) {
    .header-actions {
      display: flex;
    }
  }

  .header-actions .btn-primary {
    padding: 13px 22px;
    min-height: 0;
    border-radius: 14px;
    font-size: 0.8125rem;
  }

  .btn-sm {
    padding: 0.45rem 0.9rem;
    font-size: 0.8rem;
    min-height: 44px;
  }

  .gh {
    padding-inline: 0.75rem;
  }

  .nav-mobile {
    margin-left: auto;
  }

  @media (min-width: 960px) {
    .nav-mobile {
      display: none;
    }
  }

  .nav-burger {
    list-style: none;
    cursor: pointer;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
  }

  .nav-burger::-webkit-details-marker {
    display: none;
  }

  .nav-burger span {
    display: block;
    width: 1.1rem;
    height: 2px;
    background: var(--heading);
    border-radius: 1px;
  }

  .nav-mobile-panel {
    position: absolute;
    top: var(--header-h);
    left: 0;
    right: 0;
    padding: 1rem;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .nav-mobile-link {
    padding: 0.65rem 0.75rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    border-radius: var(--radius-sm);
  }

  .nav-mobile-link:hover,
  .nav-mobile-link.active {
    background: var(--accent-soft);
  }

  .nav-mobile[open] .nav-burger {
    border-color: var(--accent);
  }
</style>
