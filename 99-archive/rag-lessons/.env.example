# ProxyAPI / OpenAI-совместимый endpoint
# Получите ключ в личном кабинете ProxyAPI; не коммитьте реальные значения.
PROXYAPI_API_KEY=sk-your-proxyapi-key-here
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1

PROXYAPI_EMBEDDING_MODEL=text-embedding-3-large
PROXYAPI_CHAT_MODEL=gpt-4o-mini

# Опционально для «жёсткой» температуры (gpt-5 часто только дефолт — не задавать)
# PROXYAPI_CHAT_TEMPERATURE=0.2

# Pinecone — ключ и хост из консоли Pinecone (копируйте в локальный .env, не в git)
PINECONE_API_KEY=pcsk_your-pinecone-api-key-here
PINECONE_INDEX_HOST=your-index-xxxx.svc.aped-xxxxx.pinecone.io
# PINECONE_INDEX_NAME=

# Telegram — токен от @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA-your-telegram-bot-token-here

# RAG: топ-k в retrieve_context
RAG_TOP_K=5

# Лимит шагов LangGraph (узлы графа). Защита от бесконечного цикла tool→LLM→tool.
AGENT_RECURSION_LIMIT=12

# LangSmith (по умолчанию выкл. в коде)
# LANGCHAIN_TRACING_V2=false
